[gd_scene format=3 uid="uid://27ahgrkfcfg4"]

[sub_resource type="GDScript" id="GDScript_84btl"]
script/source = "
@export var climb_speed: float = 100.0

var on_ladder: bool = false
var  player_collided: bool = false

func _ready() -> void:
	Area2D.body_entered.connect(_on_body_entered)
	Area2D.body_exited.connect(_on_body_exited)
	
func _on_body_entered(body: Node) -> void:
	if body.is_in_group(\"player\"):
		player_collided = true


func _on_body_exited(body: Node) -> void:
	if body.is_in_group(\"player\"):
		player_collided = false

func _process(delta: float) -> void:
	if not on_ladder:
		return
	
	if player_collided and Input.is_action_just_pressed(\"up\"):
		player.
		
"

